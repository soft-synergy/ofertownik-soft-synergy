## Backend
PORT=5000
MONGO_URI=mongodb://localhost:27017/ofertownik
JWT_SECRET=CHANGE_ME

## AI provider
# Wybór: openrouter | anthropic
AI_PROVIDER=openrouter

# OpenRouter (zalecane – DeepSeek)
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
OPENROUTER_MODEL_FAST=deepseek/deepseek-chat
OPENROUTER_MODEL_DEEP=deepseek/deepseek-r1
OPENROUTER_MODEL_FAST_FALLBACK=meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL_DEEP_FALLBACK=deepseek/deepseek-chat

# Pełna oferta z oferty wstępnej (domyślnie: xiaomi/mimo-v2-pro)
# OPENROUTER_MODEL_OFFER_FULL=xiaomi/mimo-v2-pro

# Anthropic (opcjonalnie – jeśli przełączysz AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

# Scoring: domyślnie bez HTML (taniej). Ustaw true jeśli chcesz wysyłać pełny HTML.
USE_HTML_FOR_SCORING=false

# Przy ocenie AI >= 8/10 pełny raport (głęboka analiza) jest wysyłany na ten adres.
# Wymaga skonfigurowanego SMTP (SMTP_HOST, SMTP_USER, SMTP_PASS).
PUBLIC_ORDER_REPORT_EMAIL=twoj@email.pl

# Stały klucz integracyjny dla Claude / automatyzacji.
CLAUDE_API_KEY=generate-a-long-random-secret-here
CLAUDE_API_USER_EMAIL=claude-api@soft-synergy.local
CLAUDE_API_SCOPES=tasks:read,tasks:write,projects:read,users:read

# Powiadomienia przetargów „Robimy”: maile (termin, update, zaznaczenie). Wiele adresów po przecinku.
# Jeśli puste – maile dostają wszyscy aktywni admini.
# PUBLIC_ORDER_NOTIFY_EMAIL=info@firma.pl,jakub@firma.pl

## Biznes-Polska scraping (opcjonalny override; domyślnie jest zahardkodowane w kodzie)
# BIZNES_POLSKA_COOKIES=...
